#avenger.rules for Suricata 8.x
#CVE-2026-1731 - Websocket-based Command Injection in BeyondTrust Remote Support/Privileged Remote Access products.
#Requires the use of the websocket protocol header, and the websocket.payload sticky buffer.
#If sid sid:700000 is alerting excessively in your environment, consider adding the "noalert" keyword to your environment to reduce false positives.
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SPECIFIC_APPS Possible BeyondTrust Remote Support/Privileged Remote Access Request to Vulnerable Websocket Endpoint (CVE-2026-1731)"; flow:established,to_server; flowbits:set,ET.CVE.2026-1731; http.method; content:"GET"; http.uri; bsize:3; content:"/ne"; http.header_names; to_lowercase; content:"|0d 0a|x-ns-company|0d 0a|"; fast_pattern; content:"|0d 0a|upgrade|0d 0a|"; reference:url,https://attackerkb.com/topics/jNMBccstay/cve-2026-1731/rapid7-analysis; reference:cve,2026-1731; classtype:attempted-admin; sid:700000; rev:1; metadata:affected_product BeyondTrust, tls_state TLSDecrypt, created_at 2026_02_12, cve CVE_2026_1731, deployment Perimeter, deployment Internal, confidence High, signature_severity Major, mitre_tactic_id TA0001, mitre_tactic_name Initial_Access, mitre_technique_id T1190, mitre_technique_name Exploit_Public_Facing_Application, mitre_tactic_id TA0008, mitre_tactic_name Lateral_Movement, mitre_technique_id T1210, mitre_technique_name Exploitation_Of_Remote_Services; target:dest_ip;)
alert websocket $EXTERNAL_NET any -> $HOME_NET any (msg:"ET WEB_SPECIFIC_APPS BeyondTrust Remote Support/Privileged Remote Access Websocket Command Injection Attempt(CVE-2026-1731)"; flow:established,to_server; websocket.payload; content:"|5b 24|"; depth:10; fast_pattern; pcre:"/^[^\x26]*?(?:(?:\x3b|%3[Bb])|(?:\x0a|%0[Aa])|(?:\x60|%60)|(?:\x7c|%7[Cc])|(?:\x24|%24))+/"; reference:url,https://attackerkb.com/topics/jNMBccstay/cve-2026-1731/rapid7-analysis; reference:cve,2026-1731; classtype:attempted-admin; sid:700000; rev:1; metadata:affected_product BeyondTrust, tls_state TLSDecrypt, created_at 2026_02_12, cve CVE_2026_1731, deployment Perimeter, deployment Internal, confidence High, signature_severity Major, mitre_tactic_id TA0001, mitre_tactic_name Initial_Access, mitre_technique_id T1190, mitre_technique_name Exploit_Public_Facing_Application, mitre_tactic_id TA0008, mitre_tactic_name Lateral_Movement, mitre_technique_id T1210, mitre_technique_name Exploitation_Of_Remote_Services; target:dest_ip;)