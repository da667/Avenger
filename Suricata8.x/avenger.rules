alert websocket $HOME_NET any -> $EXTERNAL_NET any (msg:"AVENGER MALWARE Silver Fox ABCDoor Host Details Data Exfiltration Attempt"; flow:established,to_server; websocket.payload; content:"|5b 22|auth|22 2c 7b 22|role|22 3a 22|client|22|"; fast_pattern; content:"|22|device_info|22 3a 7b 22|"; content:"|22|computer_name|22 3a 22|"; content:"|22|os_name|22 3a 22|Windows|22|"; content:"|22|os_version|22 3a 22|"; content:"|22|os_release|22 3a 22|"; content:"|22|version|22 3a|"; reference:url,securelist.com/silver-fox-tax-notification-campaign/119575/; classtype:trojan-activity; sid:7000005; rev:1; metadata:affected_product Windows_11, affected_product Windows_XP/Vista/7/8/10/Server_32/64bit tls_state plaintext, created_at 2026_05_07,deployment Perimeter, confidence High, signature_severity Major, mitre_tactic_id TA0011, mitre_tactic_name Command_and_Control, mitre_technique_id T1041, mitre_technique_name Exfiltration_Over_C2_Channel; target:src_ip;)
