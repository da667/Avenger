#avenger.rules for Suricata 8.x
#CVE-2026-1731 - Websocket-based Command Injection in BeyondTrust Remote Support/Privileged Remote Access products.
#Requires the use of the websocket protocol header, and the websocket.payload sticky buffer.
#If sid sid:7000000 is alerting excessively in your environment, consider adding the "noalert" keyword to your environment to reduce false positives.
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"AVENGER WEB_SPECIFIC_APPS Possible BeyondTrust Remote Support/Privileged Remote Access Request to Vulnerable Websocket Endpoint"; flow:established,to_server; flowbits:set,ET.BeyondTrust.WebSocket.Upgrade; http.method; content:"GET"; http.uri; bsize:3; content:"/n"; startswith; pcre:"/^[ew]/R"; http.header; content:"sec-websocket-protocol|3a 20|ingredi support desk customer thin"; fast_pattern; http.header_names; to_lowercase; content:"|0d 0a|x-ns-company|0d 0a|"; content:"|0d 0a|upgrade|0d 0a|"; reference:url,attackerkb.com/topics/jNMBccstay/cve-2026-1731/rapid7-analysis; reference:url,attackerkb.com/topics/G5s8ZWAbYH/cve-2024-12356/rapid7-analysis; reference:cve,2026-1731; reference:cve,2024-12356; classtype:attempted-admin; sid:7000000; rev:3; metadata:affected_product BeyondTrust, tls_state TLSDecrypt, created_at 2026_02_12, cve CVE_2026_1731, cve CVE_2024_12356, deployment Perimeter, deployment Internal, confidence High, signature_severity Major, mitre_tactic_id TA0001, mitre_tactic_name Initial_Access, mitre_technique_id T1190, mitre_technique_name Exploit_Public_Facing_Application, mitre_tactic_id TA0008, mitre_tactic_name Lateral_Movement, mitre_technique_id T1210, mitre_technique_name Exploitation_Of_Remote_Services; target:dest_ip;)
alert websocket $EXTERNAL_NET any -> $HOME_NET any (msg:"AVENGER WEB_SPECIFIC_APPS BeyondTrust Remote Support/Privileged Remote Access Websocket Command Injection Attempt(CVE-2026-1731)"; flow:established,to_server; flowbits:isset,ET.BeyondTrust.WebSocket.Upgrade; websocket.payload; content:"|5b 24|"; depth:10; fast_pattern; pcre:"/^[^\x26]*?(?:(?:\x3b|%3[Bb])|(?:\x0a|%0[Aa])|(?:\x60|%60)|(?:\x7c|%7[Cc])|(?:\x24|%24))+/"; reference:url,attackerkb.com/topics/jNMBccstay/cve-2026-1731/rapid7-analysis; reference:cve,2026-1731; classtype:attempted-admin; sid:7000001; rev:3; metadata:affected_product BeyondTrust, tls_state TLSDecrypt, created_at 2026_02_12, cve CVE_2026_1731, deployment Perimeter, deployment Internal, confidence High, signature_severity Major, mitre_tactic_id TA0001, mitre_tactic_name Initial_Access, mitre_technique_id T1190, mitre_technique_name Exploit_Public_Facing_Application, mitre_tactic_id TA0008, mitre_tactic_name Lateral_Movement, mitre_technique_id T1210, mitre_technique_name Exploitation_Of_Remote_Services; target:dest_ip;)
#CVE-2024-12356 - Websocket-based Command Injection in BeyondTrust Remote Support/Privileged Remote Access products.
#Requires the use of the websocket protocol header, and the websocket.payload sticky buffer.
alert websocket $EXTERNAL_NET any -> $HOME_NET any (msg:"AVENGER WEB_SPECIFIC_APPS BeyondTrust Remote Support/Privileged Remote Access Websocket Command Injection Attempt (CVE-2024-12356)"; flow:established,to_server; flowbits:isset,ET.BeyondTrust.WebSocket.Upgrade; websocket.payload; content:"1"; startswith; pcre:"/[a-f0-9]{8}\x2d(?:[a-f0-9]{4}\x2d){2}[a-f0-9]{12}/R"; content:"0"; within:5; content:"|27 3b 20 5c 5c 21|"; fast_pattern; within:15; reference:url,attackerkb.com/topics/G5s8ZWAbYH/cve-2024-12356/rapid7-analysis; reference:cve,2024-12356; classtype:attempted-admin; sid:7000002; rev:1; metadata:affected_product BeyondTrust, tls_state TLSDecrypt, created_at 2026_02_13, cve CVE_2024_12356, deployment Perimeter, deployment Internal, confidence High, signature_severity Major, mitre_tactic_id TA0001, mitre_tactic_name Initial_Access, mitre_technique_id T1190, mitre_technique_name Exploit_Public_Facing_Application, mitre_tactic_id TA0008, mitre_tactic_name Lateral_Movement, mitre_technique_id T1210, mitre_technique_name Exploitation_Of_Remote_Services; target:dest_ip;)
#Silver Fox APT ABCDoor Websocket Activity
alert websocket $HOME_NET any -> $EXTERNAL_NET any (msg:"AVENGER MALWARE Silver Fox ABCDoor Beacon Attempt"; flow:established,to_server; websocket.payload; content:"probe"; fast_pattern; endswith; pcre:"/^\d{1,2}probe$/"; reference:url,securelist.com/silver-fox-tax-notification-campaign/119575/; classtype:trojan-activity; sid:7000003; rev:1; metadata:affected_product Windows_11, affected_product Windows_XP/Vista/7/8/10/Server_32/64bit tls_state plaintext, created_at 2026_05_07,deployment Perimeter, confidence High, signature_severity Major, mitre_tactic_id TA0011, mitre_tactic_name Command_and_Control, mitre_technique_id T1041, mitre_technique_name Exfiltration_Over_C2_Channel; target:src_ip;)
